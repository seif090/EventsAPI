{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=EventsDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "EventsAPI",
    "Audience": "EventsAPI",
    "Key": "CHANGE_THIS_TO_A_SECURE_KEY_32_CHARS_MIN",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 14
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "EventsApi"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Information"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
